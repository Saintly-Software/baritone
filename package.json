{
  "name": "@saintly-software/baritone",
  "version": "1.0.0-alpha.0",
  "description": "A whitelabel-first React design system built on vanilla-extract + base-ui, using an Intent/Saliency colour model with oklch relative-colour interaction states.",
  "type": "module",
  "license": "ISC",
  "author": "",
  "packageManager": "pnpm@11.8.0",
  "keywords": [
    "design-system",
    "react",
    "vanilla-extract",
    "base-ui",
    "oklch",
    "whitelabel"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "pnpm fmt --check",
    "pub:version": "pnpm exec changeset version",
    "pub:release": "pnpm build && pnpm exec changeset publish"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@vanilla-extract/css": {
      "optional": true
    }
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@changesets/cli": "^2.27.0",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
